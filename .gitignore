# ─── DEPENDENCIES ─────────────────────────────────────────────────────
# Chặn node_modules ở mọi cấp độ (Root, Apps, Packages)
node_modules
.pnpm-store

# ─── BUILD OUTPUTS (FRONTEND & BACKEND) ──────────────────────────────
# Dùng wildcard (*) để tự động ăn theo cả apps/frontend, apps/backend, v.v.
.next/
out/
dist/
build/
apps/*/.next/
apps/*/out/
apps/*/dist/
apps/*/build/
packages/*/dist/
packages/*/build/

# ─── TESTING & CACHE ──────────────────────────────────────────────────
apps/backend/thunder-tests/
apps/backend/.tscache/
.turbo
apps/*/.turbo
packages/*/.turbo
.coverage
*.lcov

# ─── SECURITY & ENVIRONMENT VARIABLES (QUAN TRỌNG) ────────────────────
# Bắt tất cả các file .env, .env.local, .env.test, .env.production ở MỌI cấp thư mục
.env
.env.*
*.env
*.env.*
apps/*/.env*
packages/*/.env*

# NGOẠI TRỪ file mẫu (để người khác clone về biết đường điền key)
!.env.example
!apps/*/.env.example
!packages/*/.env.example

# ─── OPERATING SYSTEM FILES ───────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
ehthumbs.db
desktop.ini

# ─── LOGS AND DIAGNOSTICS ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
*.log

# ─── IDE & EDITORS ────────────────────────────────────────────────────
.continue
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?